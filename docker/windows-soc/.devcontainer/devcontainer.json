{
  "name": "NFCSOC — Windows SOC Lab",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "windows-soc",
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "postAttachCommand": "pwsh /lab/profile.ps1",
  "customizations": {
    "vscode": {
      "extensions": ["ms-vscode.powershell"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "pwsh"
      }
    }
  },
  "portsAttributes": {},
  "forwardPorts": []
}
